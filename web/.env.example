# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used for SEO URLs (OpenGraph, sitemap, robots).
# Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# Server-only — required for /api/at/bundle (UID customer portal)
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: protect /api/at/bundle in production (?secret= or header x-at-secret)
# AT_SHARED_SECRET=

# Portal shared secret for browser -> API requests.
# This is a "shared" secret used for auth of the customer portal API endpoints.
NEXT_PUBLIC_AT_SHARED_SECRET=

# Google token verification (recommended)
# Your Google OAuth Client ID (the one used by Webflow / your Google login flow).
GOOGLE_OAUTH_CLIENT_ID=

# Optional: protect /api/auth/verify-google from public abuse
WEBFLOW_AUTH_SHARED_SECRET=
